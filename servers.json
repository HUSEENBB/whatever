              "auth": "noauth",
              "udp": true
            }
          }
        ],
        "outbounds": [
          {
            "protocol": "vless",
            "settings": {
              "vnext": [
                {
                  "address": "162.159.153.247",
                  "port": 80,
                  "users": [
                    {
                      "id": "app",
                      "encryption": "none"
                    }
                  ]
                }
              ]
            },
            "streamSettings": {
              "network": "ws",
              "security": "none",
              "wsSettings": {
                "path": "/@w3uz2",
                "headers": {
                  "Host": "ab.eshop2.shop"
                }
              }
            }
          }
        ]
      }
    },

